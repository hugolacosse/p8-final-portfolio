 ---
 const { image, url, code, title, tags, description } = Astro.props;
 ---

<article class="flex flex-col w-[350px] bg-[#313552] rounded-lg">
    <a class="flex-none h-auto overflow-hidden" href={url}>
        <img class="rounded-t-lg h-auto w-100" src={image.src} alt="Photo de couverture du projet" fetchpriority="high"/>
    </a>
    <div class="flex flex-col flex-auto p-[40px_32px] items-start">
        <p class="text-[#ffc576] font-semibold text-sm uppercase">{tags}</p>
        <a class="transition-(--project-name) hover:text-[#ffc576]" href={url}><h2 class="text-2xl font-semibold m-[10px_0px_20px_0px]">{title}</h2></a>
        <p class="mb-[50px] text-lg">{description}</p>
        <a class="mt-auto hover:bg-[#ffc576] hover:text-[#1f2235] duration-300 ease-in-out
            inline-flex items-center p-[7px_30px] rounded-xs
            text-sm leading-[2] text-[#ffc576] font-semibold uppercase
            border-1 border-[#ffc576]" href={url}>
            En savoir plus
        </a>
        <a class="mt-4 hover:bg-[#ffc576] hover:text-[#1f2235] duration-300 ease-in-out
            inline-flex items-center p-[7px_30px] rounded-xs
            text-sm leading-[2] text-[#ffc576] font-semibold uppercase
            border-1 border-[#ffc576]" href={code} target="_blank">
            Voir le code
        </a>
    </div>
</article>