---
import '../styles/global.css'

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---
<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/p8-final-portfolio/favicon.svg" />
		<link rel="icon" href="/p8-final-portfolio/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Hugo Lacosse</title>
		<meta name="description" content="Hugo Lacosse, Développeur Web">
	</head>
	<body class="bg-[#1f2235] text-white min-h-screen flex flex-col">
		<Header />
		<main class="w-screen flex-grow flex flex-col pt-16">
			<slot />
		</main>
		<Footer  />
	</body>
</html>

